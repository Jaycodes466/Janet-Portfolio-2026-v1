    <div class="footer-left">
      <div class="footer-logo-container">
        <a href="#" class="footer-logo">Janet McDonald</a>
      </div>
      <p class="footer-description">
        Janet McDonald is a design professional specializing in brand design,
        Showit websites, and freelance graphic design services.
      </p>
    </div>
    <div class="footer-right">
      <div class="footer-nav">
        <ul>
          <li><a href="#">Home</a></li>
          <li><a href="#">Portfolio</a></li>
          <li><a href="#">About</a></li>
          <a href="/contact" class="footer-contact-btn">Contact</a>
        </ul>
      </div>
      <div class="footer-gallery">
        <Image
          class="footer-gallery-img"
          src={footerOne}
          alt="Icon"
          width={165}
          height={165}
          sizes="(max-width: 768px) 120px, 165px"
        />
        <Image
          class="footer-gallery-img"
          src={footerTwo}
          alt="Icon"
          width={165}
          height={165}
          sizes="(max-width: 768px) 120px, 165px"
