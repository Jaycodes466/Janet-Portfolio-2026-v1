---
import profile from "../assets/about-img.png";
import { Image } from "astro:assets";
---

<section class="learn-more">
  <div class="learn-more-img-container">
    <Image
      class="profile-img"
      src={profile}
      alt="Profile image"
      width={360}
      height={380}
      sizes="(max-width: 768px) 332px, 420px"
    />
  </div>
  <div class="learn-more-text-content">
    <h3 class="learn-more-title">
      Hi, <span class="fancy-font">I'm </span>Janet
    </h3>

    <p class="learn-more-desc">
      I’m a visual designer who takes the time to understand the heart of your
      business and translate it into thoughtful, purposeful design.
    </p>
    <p class="learn-more-desc">
      My passion lies in helping others make their vision a reality through
      creating designs that stand out, reach the right audience, and honor where
      they want to go.
    </p>
    <a href="#" class="btn learn-more-btn">Get to know me</a>
  </div>
</section>
